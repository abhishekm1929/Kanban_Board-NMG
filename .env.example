# ─── Slack ────────────────────────────────────────────────────────────────────
# Get these from api.slack.com/apps → your app → OAuth & Permissions
SLACK_APP_TOKEN=xapp-your-app-level-token-here
SLACK_BOT_TOKEN=xoxb-your-bot-user-oauth-token-here

# ─── Model providers (pick at least one) ──────────────────────────────────────
# Groq — free key from console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key-here

# Google Gemini — free key from aistudio.google.com
GEMINI_API_KEY=AIzaSy_your-gemini-key-here

# Ollama — no key needed (local), just run: ollama pull qwen2.5-coder

# ─── Laravel backend ──────────────────────────────────────────────────────────
APP_KEY=base64:your-generated-key-here
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=sqlite
# DB_DATABASE=absolute/path/to/database.sqlite   ← leave blank to use default

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
